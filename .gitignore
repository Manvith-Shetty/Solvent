# Rust / Cargo build output
target/
**/target/

# Soroban test snapshots (regenerated by `cargo test`)
contracts/**/test_snapshots/

# Large proving artifacts (regenerated by scripts/gen_proof.sh).
# We keep the small, load-bearing outputs (proof.json, public.json,
# verification_key.json, and the packed onchain/*.hex) so the repo is
# verifiable without re-running a multi-minute trusted setup.
circuits/build/*.ptau
circuits/build/*.zkey
circuits/build/*.wtns
circuits/build/*.r1cs
circuits/build/solvency_js/

# Node
node_modules/
package-lock.json

# Deploy secrets / local env
.env
deploy/.soroban/
deploy/*.secret

# Editor / OS cruft
*.swp
.DS_Store
claude_output.txt
